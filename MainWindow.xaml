<Window x:Class="HeartRateMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:local="clr-namespace:HeartRateMonitor"
        Title="MultiHR_win" Height="800" Width="1200" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <Window.Resources>
        <!-- 定义颜色资源（调整为柔和色调） -->
        <SolidColorBrush x:Key="DefaultButtonBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="ActiveButtonBrush" Color="#C8E6C9"/>
        <SolidColorBrush x:Key="BorderSoftBrush" Color="#DDDDDD"/>
        <SolidColorBrush x:Key="BackgroundSoftBrush" Color="#FEFEFE"/>
        <SolidColorBrush x:Key="TextSoftBrush" Color="#333333"/>
        <SolidColorBrush x:Key="TitleTextSoftBrush" Color="#222222"/>
        <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#F0F0F0"/>

        <!-- 颜色选项列表（用于绑定） -->
        <x:Array x:Key="ColorOptions" Type="local:ColorOption">
            <local:ColorOption Name="红色" Color="#FF0000"/>
            <local:ColorOption Name="深绿" Color="#006400"/>
            <local:ColorOption Name="紫色" Color="#800080"/>
            <local:ColorOption Name="黑色" Color="#000000"/>
            <local:ColorOption Name="深蓝" Color="#00008B"/>
        </x:Array>

        <!-- OxyColor 转 Brush 转换器 -->
        <local:OxyColorToBrushConverter x:Key="OxyColorToBrushConverter"/>

        <!-- 圆角GroupBox样式（保持不变） -->
        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.RowSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource BorderSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" 
                                            Background="{StaticResource BackgroundSoftBrush}"
                                            BorderBrush="Transparent"
                                            CornerRadius="8,8,0,0"
                                            Padding="8,4,8,6"
                                            Margin="1,1,1,0">
                                        <TextBlock Text="{TemplateBinding Header}" 
                                                   FontSize="14" 
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TitleTextSoftBrush}"
                                                   HorizontalAlignment="Left"/>
                                    </Border>

                                    <Border Grid.Row="1" 
                                            CornerRadius="0,0,8,8"
                                            Padding="{TemplateBinding Padding}"
                                            Margin="1,0,1,1">
                                        <ContentPresenter ContentSource="Content"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 大尺寸按钮字体样式 -->
        <Style x:Key="LargeButtonTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}"/>
        </Style>

        <!-- 文本标签样式 -->
        <Style x:Key="ControlLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}"/>
        </Style>

        <!-- 大圆角按钮样式 -->
        <Style x:Key="LargeRoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DefaultButtonBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="MinHeight" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8E8E8"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#CCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D8D8D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 大圆角ToggleButton样式 -->
        <Style x:Key="LargeRoundedToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource DefaultButtonBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="MinHeight" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8E8E8"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#CCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D8D8D8"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#C8E6C9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 中等圆角按钮样式 -->
        <Style x:Key="MediumRoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DefaultButtonBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8E8E8"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#CCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D8D8D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 圆角TextBox样式 -->
        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BackgroundSoftBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4D90FE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 圆角ComboBox样式 -->
        <Style x:Key="RoundedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BackgroundSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="contentPresenter" 
                                                      Margin="{TemplateBinding Padding}"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding ItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"/>
                                    <ToggleButton x:Name="toggleButton" 
                                                  Grid.Column="1"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent"
                                                  BorderBrush="Transparent"
                                                  Focusable="False">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <Path x:Name="Arrow"
                                                          Data="M0,0 L4,4 L8,0"
                                                          Fill="#666666"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Margin="0,2,0,0"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="popup" 
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder"
                                        Background="{StaticResource BackgroundSoftBrush}"
                                        BorderBrush="{StaticResource BorderSoftBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer x:Name="scrollViewer" 
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter x:Name="itemsPresenter"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#CCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4D90FE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 新增：圆角复选框样式，应用于设备图例 -->
        <Style x:Key="RoundedCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- 复选框框（带圆角） -->
                            <Border x:Name="CheckBoxBorder"
                                    Width="16" Height="16"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    VerticalAlignment="Center"
                                    Margin="0,0,4,0">
                                <Path x:Name="CheckMark"
                                      Data="M4,8 L7,11 L12,4"
                                      Stroke="Green"
                                      StrokeThickness="2"
                                      Visibility="Collapsed"/>
                            </Border>
                            <!-- 内容（颜色圆点+文字） -->
                            <ContentPresenter x:Name="contentPresenter"
                                              Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#999999"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" MinWidth="300"/>
            <ColumnDefinition Width="2*" MinWidth="600"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧功能区（1/3宽度） -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" MinHeight="150"/>
                <RowDefinition Height="1*" MinHeight="150"/>
                <RowDefinition Height="1*" MinHeight="150"/>
            </Grid.RowDefinitions>

            <!-- 扫描控制区 -->
            <GroupBox Header="扫描控制" Grid.Row="0" Padding="8" Background="Transparent">
                <Border BorderBrush="{StaticResource BorderSoftBrush}" 
                        BorderThickness="2" 
                        CornerRadius="8" 
                        Background="{StaticResource BackgroundSoftBrush}"
                        Padding="5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <Button x:Name="BtnScan" Content="扫描设备" Click="BtnScan_Click" 
                                    Style="{StaticResource LargeRoundedButtonStyle}" Margin="0,0,15,0"/>
                            <Button x:Name="BtnExportCsv" Content="导出数据" Click="ExportCsv_Click" 
                                    Style="{StaticResource LargeRoundedButtonStyle}" Background="#FFD9E8F2"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="BtnConnect" Content="连接设备" Click="BtnConnect_Click" 
                                    Style="{StaticResource LargeRoundedButtonStyle}" Margin="0,0,15,0"/>
                            <ToggleButton x:Name="BtnShowAllData" Content="显示全部" 
                                          Checked="BtnShowAllData_Checked" 
                                          Unchecked="BtnShowAllData_Unchecked"
                                          Style="{StaticResource LargeRoundedToggleButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </GroupBox>

            <!-- 扫描设备列表 -->
            <GroupBox Header="扫描到的设备" Grid.Row="1" Padding="8" Background="Transparent">
                <Border BorderBrush="{StaticResource BorderSoftBrush}" 
                        BorderThickness="2" 
                        CornerRadius="8" 
                        Background="{StaticResource BackgroundSoftBrush}"
                        Padding="5">
                    <Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" 
                                    BorderThickness="0"
                                    Background="Transparent">
                                <ListBox x:Name="DeviceList" 
                                         SelectionChanged="DeviceList_SelectionChanged"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="8,4,8,4">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Margin" Value="0,0,0,2"/>
                                            <Setter Property="Padding" Value="6,6,6,6"/>
                                            <Setter Property="Background" Value="#F9F9F9"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="ItemBorder"
                                                                BorderBrush="{StaticResource BorderSoftBrush}"
                                                                BorderThickness="2"
                                                                CornerRadius="6"
                                                                Background="{TemplateBinding Background}"
                                                                Margin="{TemplateBinding Margin}"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ItemBorder" Property="Background" Value="#F0F0F0"/>
                                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#CCCCCC"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="ItemBorder" Property="Background" Value="#E1F0FA"/>
                                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2196F3"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Advertisement.LocalName}" 
                                                           Margin="0,0,5,0" 
                                                           TextWrapping="Wrap"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextSoftBrush}"/>
                                                <TextBlock Text=" (" Foreground="#888888"/>
                                                <TextBlock Text="{Binding RawSignalStrengthInDBm}" 
                                                           Foreground="#888888"/>
                                                <TextBlock Text=" dBm)" Foreground="#888888"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <Border Grid.Column="1" 
                                    Width="8"
                                    Background="Transparent"/>
                        </Grid>
                    </Grid>
                </Border>
            </GroupBox>

            <!-- 实时数据表格 -->
            <GroupBox Header="实时数据" Grid.Row="2" Padding="8" Background="Transparent">
                <Border BorderBrush="{StaticResource BorderSoftBrush}" 
                        BorderThickness="2" 
                        CornerRadius="8" 
                        Background="{StaticResource BackgroundSoftBrush}"
                        Padding="13">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="0">
                        <ItemsControl x:Name="DevicesDataView" 
                                      BorderThickness="0"
                                      Background="Transparent"
                                      HorizontalContentAlignment="Stretch">

                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 标题行 -->
                                        <Border Grid.Row="0"
                                                BorderThickness="2" 
                                                BorderBrush="{StaticResource BorderSoftBrush}" 
                                                Padding="0,8,0,8"
                                                Margin="0,0,0,8"
                                                Background="{StaticResource HeaderBackgroundBrush}"
                                                CornerRadius="6"
                                                HorizontalAlignment="Stretch">
                                            <Grid HorizontalAlignment="Stretch" Margin="6,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="2"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="2"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="2"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="2"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="2"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="2"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="1" Background="#DDDDDD" VerticalAlignment="Stretch"/>
                                                <Border Grid.Column="3" Background="#DDDDDD" VerticalAlignment="Stretch"/>
                                                <Border Grid.Column="5" Background="#DDDDDD" VerticalAlignment="Stretch"/>
                                                <Border Grid.Column="7" Background="#DDDDDD" VerticalAlignment="Stretch"/>
                                                <Border Grid.Column="9" Background="#DDDDDD" VerticalAlignment="Stretch"/>
                                                <Border Grid.Column="11" Background="#DDDDDD" VerticalAlignment="Stretch"/>

                                                <TextBlock Grid.Column="0" 
                                                           Text="设备" 
                                                           FontWeight="Bold" FontSize="13"
                                                           Foreground="{StaticResource TitleTextSoftBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,5,0"/>
                                                <TextBlock Grid.Column="2" 
                                                           Text="心率" 
                                                           FontWeight="Bold" FontSize="13"
                                                           Foreground="{StaticResource TitleTextSoftBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,5,0"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="4" 
                                                           Text="RR" 
                                                           FontWeight="Bold" FontSize="13"
                                                           Foreground="{StaticResource TitleTextSoftBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,5,0"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="6" 
                                                           Text="SDNN" 
                                                           FontWeight="Bold" FontSize="13"
                                                           Foreground="{StaticResource TitleTextSoftBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,5,0"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="8" 
                                                           Text="HRV" 
                                                           FontWeight="Bold" FontSize="13"
                                                           Foreground="{StaticResource TitleTextSoftBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,5,0"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="10" 
                                                           Text="电量" 
                                                           FontWeight="Bold" FontSize="13"
                                                           Foreground="{StaticResource TitleTextSoftBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="12" 
                                                           Text="颜色" 
                                                           FontWeight="Bold" FontSize="13"
                                                           Foreground="{StaticResource TitleTextSoftBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <ScrollViewer Grid.Row="1" 
                                                      HorizontalScrollBarVisibility="Disabled" 
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalAlignment="Stretch">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Grid>
                                </ControlTemplate>
                            </ItemsControl.Template>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="2"
                                            BorderBrush="{StaticResource BorderSoftBrush}"
                                            CornerRadius="6"
                                            Padding="6,6,6,6"
                                            Margin="0,0,0,2"
                                            HorizontalAlignment="Stretch"
                                            Background="#F9F9F9">
                                        <Grid HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="2"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="2"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="2"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="2"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="2"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="2"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="1" Background="#DDDDDD" VerticalAlignment="Stretch"/>
                                            <Border Grid.Column="3" Background="#DDDDDD" VerticalAlignment="Stretch"/>
                                            <Border Grid.Column="5" Background="#DDDDDD" VerticalAlignment="Stretch"/>
                                            <Border Grid.Column="7" Background="#DDDDDD" VerticalAlignment="Stretch"/>
                                            <Border Grid.Column="9" Background="#DDDDDD" VerticalAlignment="Stretch"/>
                                            <Border Grid.Column="11" Background="#DDDDDD" VerticalAlignment="Stretch"/>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Alias}" 
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSoftBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,5,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Alias}"
                                                       MouseLeftButtonDown="DeviceName_MouseLeftButtonDown"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding HR, StringFormat='{}{0}', TargetNullValue='--'}" 
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSoftBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,5,0"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding LastRR, StringFormat='{}{0}', TargetNullValue='--'}" 
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSoftBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,5,0"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="6"
                                                       Text="{Binding LastSDNN, StringFormat='{}{0:F1}', TargetNullValue='--'}" 
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSoftBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,5,0"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="8"
                                                       Text="{Binding LastHRV, StringFormat='{}{0:F1}', TargetNullValue='--'}" 
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSoftBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,5,0"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="10"
                                                       Text="{Binding BatteryLevel, StringFormat='{}{0}', TargetNullValue='--'}" 
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSoftBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"/>

                                            <ComboBox Grid.Column="12"
                                                      ItemsSource="{Binding Source={StaticResource ColorOptions}}"
                                                      SelectedIndex="{Binding SelectedColorIndex}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      Width="70"
                                                      FontSize="12"
                                                      Style="{StaticResource RoundedComboBoxStyle}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Rectangle Width="12" Height="12" Margin="0,0,4,0">
                                                                <Rectangle.Fill>
                                                                    <SolidColorBrush Color="{Binding Color}"/>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="{StaticResource TextSoftBrush}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </GroupBox>
        </Grid>

        <!-- 右侧图表区 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 图表控制栏 -->
            <Grid Grid.Row="0" Margin="0,30,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Y轴范围：" Style="{StaticResource ControlLabelStyle}" Margin="0,0,8,0"/>
                    <TextBlock Text="最小值：" Style="{StaticResource ControlLabelStyle}"/>
                    <TextBox x:Name="YMinBox" Text="40" Width="65" Margin="8,0" 
                 TextAlignment="Center" Style="{StaticResource RoundedTextBoxStyle}"/>
                    <TextBlock Text="最大值：" Style="{StaticResource ControlLabelStyle}" Margin="8,0,0,0"/>
                    <TextBox x:Name="YMaxBox" Text="180" Width="65" Margin="8,0" 
                 TextAlignment="Center" Style="{StaticResource RoundedTextBoxStyle}"/>
                    <Button Content="应用" Click="ApplyYRange_Click" Margin="12,0,0,0"
                Style="{StaticResource MediumRoundedButtonStyle}" MinWidth="70"/>
                    <Button Content="重置" Click="ResetYRange_Click" Margin="8,0,0,0"
                Style="{StaticResource MediumRoundedButtonStyle}" MinWidth="70"/>
                    <Button x:Name="BtnClearChart" Content="清空曲线" Click="ClearChart_Click" 
                Margin="20,0,0,0" MinWidth="90" 
                Style="{StaticResource MediumRoundedButtonStyle}" Background="#FFE8D0C5" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- 设备图例行（应用圆角复选框样式） -->
            <Border Grid.Row="1" Margin="0,0,0,10" Padding="8" Background="#F0F0F0" CornerRadius="6">
                <ItemsControl x:Name="DeviceLegend" ItemsSource="{Binding ConnectedDevices, RelativeSource={RelativeSource AncestorType=Window}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsVisible}" 
                                      Margin="8,0" 
                                      VerticalAlignment="Center"
                                      Style="{StaticResource RoundedCheckBoxStyle}">
                                <CheckBox.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="12" Height="12" 
                                                 Fill="{Binding HrSeries.Color, Converter={StaticResource OxyColorToBrushConverter}}" 
                                                 Margin="0,0,4,0" Stroke="#888888" StrokeThickness="1"/>
                                        <TextBlock Text="{Binding Alias}" FontSize="12" Foreground="#333333"/>
                                    </StackPanel>
                                </CheckBox.Content>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- 主图表区域 -->
            <oxy:PlotView Grid.Row="2" x:Name="HrChart" Model="{Binding PlotModel}" Background="#FAFAFA" />
        </Grid>
    </Grid>
</Window>