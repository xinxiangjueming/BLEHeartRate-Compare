<Window x:Class="HeartRateMonitor.ExportOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="导出选项" Height="320" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">

    <Border Background="#FAFAFA"
            BorderBrush="#DDDDDD"
            BorderThickness="2"
            CornerRadius="12"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="导出选项" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#222222"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

            <!-- 导出类型选择 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <RadioButton x:Name="HistoryRadio" Content="历史数据" GroupName="ExportType" IsChecked="True" Margin="0,0,20,0" FontSize="14" Foreground="#333333"/>
                <RadioButton x:Name="SnapshotRadio" Content="当前快照" GroupName="ExportType" FontSize="14" Foreground="#333333"/>
            </StackPanel>

            <!-- 字段选择区域：添加 ScrollViewer 使其可滚动 -->
            <GroupBox Grid.Row="2" Header="选择要导出的字段" Margin="0,0,0,15" Padding="5"
                      BorderBrush="#DDDDDD" Foreground="#222222">
                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="200">
                    <StackPanel>
                        <CheckBox x:Name="DeviceCheckBox" Content="设备" IsChecked="True" IsEnabled="False" Margin="5" FontSize="14" Foreground="#333333"/>
                        <CheckBox x:Name="HRCheckBox" Content="心率" IsChecked="True" Margin="5" FontSize="14" Foreground="#333333"/>
                        <CheckBox x:Name="RRCheckBox" Content="RR" IsChecked="True" Margin="5" FontSize="14" Foreground="#333333"/>
                        <CheckBox x:Name="SDNNCheckBox" Content="SDNN" IsChecked="True" Margin="5" FontSize="14" Foreground="#333333"/>
                        <CheckBox x:Name="HRVCheckBox" Content="HRV" IsChecked="True" Margin="5" FontSize="14" Foreground="#333333"/>
                        <CheckBox x:Name="BatteryCheckBox" Content="电量" IsChecked="True" Margin="5" FontSize="14" Foreground="#333333"/>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>

            <!-- 按钮 -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="OkButton" 
                        Content="导出" 
                        Width="80" 
                        Height="35" 
                        Margin="0,0,15,0"
                        Background="#F5F5F5"
                        Foreground="#333333"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Click="OkButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="CancelButton" 
                        Content="取消" 
                        Width="80" 
                        Height="35"
                        Background="#F5F5F5"
                        Foreground="#333333"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Click="CancelButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>