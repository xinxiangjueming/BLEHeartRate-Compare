<Window x:Class="HeartRateMonitor.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认操作" Height="200" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">

    <Border Background="#FEFEFE"
            BorderBrush="#DDDDDD"
            BorderThickness="2"
            CornerRadius="12"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="确认操作" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#222222"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

            <TextBlock x:Name="MessageText"
                       Grid.Row="1"
                       Text="确定要断开设备连接吗？"
                       FontSize="18"
                       Foreground="#333333"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,10"/>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,15,0,0">
                <Button x:Name="YesButton" 
                        Content="是" 
                        Width="80" 
                        Height="35" 
                        Margin="0,0,15,0"
                        Background="#F5F5F5"
                        Foreground="#333333"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Click="YesButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="NoButton" 
                        Content="否" 
                        Width="80" 
                        Height="35"
                        Background="#F5F5F5"
                        Foreground="#333333"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Click="NoButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>