<Window x:Class="HeartRateMonitor.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:HeartRateMonitor.Resources"
        Title="{Binding MessageTitle, Source={StaticResource Strings}}" Height="200" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">

    <Border Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource BorderSoftBrush}"
            BorderThickness="2"
            CornerRadius="12"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding MessageTitle, Source={StaticResource Strings}}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TitleTextSoftBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

            <TextBlock x:Name="MessageText"
                       Grid.Row="1"
                       Text=""
                       FontSize="14"
                       Foreground="{DynamicResource TextSoftBrush}"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,10"/>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,15,0,0">
                <Button x:Name="OkButton"
                        Content="{Binding BtnOk, Source={StaticResource Strings}}"
                        Width="80"
                        Height="35"
                        Background="{DynamicResource DefaultButtonBrush}"
                        Foreground="{DynamicResource TextSoftBrush}"
                        BorderBrush="{DynamicResource BorderSoftBrush}"
                        BorderThickness="1"
                        Click="OkButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
