<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 主要 UI 画刷 -->
    <SolidColorBrush x:Key="DefaultButtonBrush" Color="#3C3C3C"/>
    <SolidColorBrush x:Key="ActiveButtonBrush" Color="#378B3A"/>
    <SolidColorBrush x:Key="BorderSoftBrush" Color="#555555"/>
    <SolidColorBrush x:Key="BackgroundSoftBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="TextSoftBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TitleTextSoftBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E"/>

    <!-- 按钮交互状态 -->
    <SolidColorBrush x:Key="ButtonMouseOverBrush" Color="#505050"/>
    <SolidColorBrush x:Key="ButtonMouseOverBorderBrush" Color="#666666"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#606060"/>
    <SolidColorBrush x:Key="ButtonCheckedBrush" Color="#7600C2"/>

    <!-- 输入控件 -->
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#4D90FE"/>
    <SolidColorBrush x:Key="ComboBoxArrowBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="CheckBoxHoverBorderBrush" Color="#888888"/>
    <SolidColorBrush x:Key="CheckBoxPressedBackgroundBrush" Color="#505050"/>

    <!-- ScrollBar -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#606060"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#808080"/>
    <SolidColorBrush x:Key="ScrollBarThumbDraggingBrush" Color="#A0A0A0"/>

    <!-- 列表/表格 -->
    <SolidColorBrush x:Key="ListItemBackgroundBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="ListItemHoverBackgroundBrush" Color="#383838"/>
    <SolidColorBrush x:Key="ListItemSelectedBackgroundBrush" Color="#1171B0"/>
    <SolidColorBrush x:Key="TableSeparatorBrush" Color="#555555"/>

    <!-- 交互色 -->
    <SolidColorBrush x:Key="LinkBlueBrush" Color="#006CC2"/>
    <SolidColorBrush x:Key="LinkRedBrush" Color="#B70F0B"/>
    <SolidColorBrush x:Key="RecordGreenBrush" Color="#378B3A"/>
    <SolidColorBrush x:Key="ExportBlueBrush" Color="#2A6C98"/>
    <SolidColorBrush x:Key="ClearChartBrush" Color="#914F31"/>
    <SolidColorBrush x:Key="RadioButtonForegroundBrush" Color="#E0E0E0"/>

    <!-- 控件细节 -->
    <SolidColorBrush x:Key="CheckMarkStrokeBrush" Color="#66BB6A"/>
    <SolidColorBrush x:Key="LegendDotStrokeBrush" Color="#666666"/>

    <!-- 图表区域 -->
    <SolidColorBrush x:Key="ChartBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ChartLegendBackgroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="ChartLegendForegroundBrush" Color="#E0E0E0"/>

</ResourceDictionary>
