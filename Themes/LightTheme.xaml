<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 主要 UI 画刷 -->
    <SolidColorBrush x:Key="DefaultButtonBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="ActiveButtonBrush" Color="#C8E6C9"/>
    <SolidColorBrush x:Key="BorderSoftBrush" Color="#DDDDDD"/>
    <SolidColorBrush x:Key="BackgroundSoftBrush" Color="#FEFEFE"/>
    <SolidColorBrush x:Key="TextSoftBrush" Color="#333333"/>
    <SolidColorBrush x:Key="TitleTextSoftBrush" Color="#222222"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FAFAFA"/>

    <!-- 按钮交互状态 -->
    <SolidColorBrush x:Key="ButtonMouseOverBrush" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="ButtonMouseOverBorderBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#D8D8D8"/>
    <SolidColorBrush x:Key="ButtonCheckedBrush" Color="#E0B0FF"/>

    <!-- 输入控件 -->
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#4D90FE"/>
    <SolidColorBrush x:Key="ComboBoxArrowBrush" Color="#666666"/>
    <SolidColorBrush x:Key="CheckBoxHoverBorderBrush" Color="#999999"/>
    <SolidColorBrush x:Key="CheckBoxPressedBackgroundBrush" Color="#E0E0E0"/>

    <!-- ScrollBar -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#BDBDBD"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#9E9E9E"/>
    <SolidColorBrush x:Key="ScrollBarThumbDraggingBrush" Color="#757575"/>

    <!-- 列表/表格 -->
    <SolidColorBrush x:Key="ListItemBackgroundBrush" Color="#F9F9F9"/>
    <SolidColorBrush x:Key="ListItemHoverBackgroundBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ListItemSelectedBackgroundBrush" Color="#E1F0FA"/>
    <SolidColorBrush x:Key="TableSeparatorBrush" Color="#DDDDDD"/>

    <!-- 交互色 -->
    <SolidColorBrush x:Key="LinkBlueBrush" Color="#2196F3"/>
    <SolidColorBrush x:Key="LinkRedBrush" Color="#E53935"/>
    <SolidColorBrush x:Key="RecordGreenBrush" Color="#C8E6C9"/>
    <SolidColorBrush x:Key="ExportBlueBrush" Color="#FFD9E8F2"/>
    <SolidColorBrush x:Key="ClearChartBrush" Color="#FFE8D0C5"/>
    <SolidColorBrush x:Key="RadioButtonForegroundBrush" Color="#333333"/>

    <!-- 控件细节 -->
    <SolidColorBrush x:Key="CheckMarkStrokeBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="LegendDotStrokeBrush" Color="#888888"/>

    <!-- 标题栏 -->
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="TitleBarCaptionBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="TitleBarButtonBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#D0D0D0"/>
    <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#C42B1C"/>
    <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#C42B1C"/>
    <SolidColorBrush x:Key="TitleBarButtonIconBrush" Color="#1A1A1A"/>

    <!-- 图表区域 -->
    <SolidColorBrush x:Key="ChartBackgroundBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="ChartLegendBackgroundBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ChartLegendForegroundBrush" Color="#333333"/>

</ResourceDictionary>
